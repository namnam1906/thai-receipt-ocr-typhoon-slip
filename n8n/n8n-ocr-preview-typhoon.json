        "respondWith": "json",
        "responseBody": "={{$json}}",
        "options": {}
      },
      "id": "f20e3b31-1355-4e91-8224-61591ef3dacf",
      "name": "Respond Preview",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        480,
        0
      ]
    }
  ],
